rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── lockers collection ──────────────────────────────────────────────
    // App (unauthenticated) boleh READ lockers untuk dashboard
    // Hanya Admin SDK (Cloud Functions) yang boleh WRITE
    match /lockers/{lockerId} {
      allow read: if true;
      allow write: if false; // Cloud Functions menggunakan Admin SDK (bypass rules)
    }

    // ── transactions collection ─────────────────────────────────────────
    // Tidak ada akses langsung dari App
    // Hanya Cloud Functions (Admin SDK) yang boleh read/write
    match /transactions/{transactionId} {
      allow read, write: if false;
    }

    // ── Semua dokumen lain: deny by default ─────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
